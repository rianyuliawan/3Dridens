# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Supabase (required for Phase 1: auth, database, storage) ---
# Found in Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, NEVER expose to the browser. Used only by
# the Midtrans webhook and admin-verified privileged writes in later phases.
SUPABASE_SERVICE_ROLE_KEY=

# --- Midtrans (payments) ---
# Found in Midtrans Dashboard > Settings > Access Keys. Start with the
# Sandbox keys while developing; switch to Production keys before go-live.
MIDTRANS_SERVER_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# Set to "true" only when using Production keys. Leave unset/false for Sandbox.
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false
